#!/usr/bin/env bash
#
# pre-commit hook — 하드코딩된 secret 패턴이 커밋되는 것을 차단합니다 (PY001 방지).
#
# 활성화:
#   git config core.hooksPath .githooks
#
# 우회가 꼭 필요한 경우(권장하지 않음):
#   git commit --no-verify
#
set -euo pipefail

# 스테이징된(추가/수정) 텍스트 파일만 검사
files=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$files" ] && exit 0

# 차단할 secret 패턴 (확장 정규식)
patterns=(
  'sk-ant-[A-Za-z0-9_-]+'                 # Anthropic API key
  'gh[pousr]_[A-Za-z0-9]{20,}'            # GitHub token
  'AKIA[0-9A-Z]{16}'                      # AWS access key id
  '-----BEGIN [A-Z ]*PRIVATE KEY-----'    # private key block
)

found=0
for f in $files; do
  # 바이너리 파일 건너뛰기
  if git diff --cached -- "$f" | grep -Iq .; then :; else continue; fi
  for p in "${patterns[@]}"; do
    # 추가된 라인(+)만 검사
    if git diff --cached -U0 -- "$f" | grep -E '^\+' | grep -Eq "$p"; then
      echo "❌ 하드코딩된 secret 패턴 감지: $f  (패턴: $p)"
      found=1
    fi
  done
done

if [ "$found" -ne 0 ]; then
  echo ""
  echo "커밋이 차단되었습니다. 실제 secret 은 절대 커밋하지 마세요."
  echo "운영에서는 CI/CD secret 변수 · Sealed Secrets · External Secrets Operator 를 사용하세요."
  echo "예시/placeholder 라서 안전하다고 확신하면: git commit --no-verify"
  exit 1
fi

exit 0
